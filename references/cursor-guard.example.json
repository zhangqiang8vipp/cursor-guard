{
  "protect": [
    "src/**",
    "lib/**",
    "*.config.js",
    "*.config.ts",
    "package.json",
    "tsconfig.json",
    ".env.example"
  ],
  "ignore": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".next/**",
    "coverage/**",
    "*.log",
    "*.tmp",
    ".cursor-guard-backup/**"
  ],
  "backup_strategy": "git",
  "auto_backup_interval_seconds": 60,
  "secrets_patterns": [
    ".env",
    ".env.*",
    "*.key",
    "*.pem"
  ],
  "pre_restore_backup": "always",
  "retention": {
    "mode": "days",
    "days": 30,
    "max_count": 100,
    "max_size_mb": 500
  },
  "git_retention": {
    "enabled": false,
    "mode": "count",
    "days": 30,
    "max_count": 200
  }
}
